# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local osquery runtime files
/local_osquery.db/
/local_osquery.db
/local_osquery.pid

# employee configuration file (contains private user info)
/employee.json

# local testing configurations and secrets
/local_enroll_secret
/local_osquery.conf
/local_osquery.flags
/settings.json
/dribbble_design.png
